DATABASE_URL=postgres://postgres:postgres@localhost:5432/finbro
JWT_SECRET=change_me

# Primary AI provider for in-app FinBro chat.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Primary YandexGPT provider.
YANDEX_API_KEY=your_yandex_cloud_api_key_here
YANDEX_FOLDER_ID=your_yandex_cloud_folder_id_here
YANDEXGPT_MODEL=yandexgpt/latest

# Optional: if empty, YANDEX_API_KEY is used for SpeechKit STT too.
YANDEX_SPEECHKIT_KEY=
